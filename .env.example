# ──────────────────────────────────────────────
# Обов'язкові змінні — виставити у Vercel Dashboard
# Settings → Environment Variables
# ──────────────────────────────────────────────

# База даних (Neon / Supabase / будь-який PostgreSQL)
# Отримати на: https://console.neon.tech → Connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Адмін-акаунт для входу в /admin
# Після зміни запустити: npm run db:seed
ADMIN_USERNAME="your_admin_login"
ADMIN_PASSWORD="YourStrongPassword123!"

# JWT-секрет для підпису сесійних токенів (мін. 32 символи)
# Генерувати: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"

# Публічна URL-адреса додатку (без слеша в кінці)
NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"

# Vercel Blob — сховище для фото страв (потрібен лише на production)
# Отримати: Vercel Dashboard → Storage → Create Blob Store → .env.local
# На локалці НЕ потрібен — фото зберігаються у public/uploads/
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"
